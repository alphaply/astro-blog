---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title?: string;
  description?: string;
}

const siteName = 'Alpha Blog';
const {
  title = siteName,
  description = 'Alpha Blog：生活、知识与作品记录。',
} = Astro.props;

const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="ambient-bg" aria-hidden="true"></div>
    <header class="site-header">
      <nav class="nav" aria-label="主导航">
        <a class="brand" href="/">
          <span class="brand-mark">A</span>
          <span>{siteName}</span>
        </a>
        <div class="nav-links">
          <a href="/">文章</a>
          <a href="/archives/">归档</a>
          <a href="/notes/">说说</a>
          <a href="/categories/">分类</a>
          <a href="/tags/">标签</a>
          <a href="/portfolio/">作品</a>
          <a href="/guestbook/">留言</a>
          <a href="/search/">搜索</a>
        </div>
      </nav>
    </header>
    <main data-pagefind-body>
      <slot />
    </main>
    <footer class="site-footer">
      <span>Alpha Blog · MDX powered static notes</span>
      <a href="/archives/">查看归档</a>
    </footer>
    <script is:inline>
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const reveal = target.closest('.spoiler-text');
        if (reveal) reveal.classList.toggle('is-revealed');
      });
    </script>
    <script is:inline>
      const loadMermaid = () =>
        import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');

      const renderMermaid = async () => {
        const blocks = [...document.querySelectorAll('.expressive-code pre code.language-mermaid, pre code.language-mermaid')];
        if (!blocks.length) return;
        const { default: mermaid } = await loadMermaid();
        mermaid.initialize({
          startOnLoad: false,
          securityLevel: 'strict',
          theme: window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'base',
          themeVariables: {
            primaryColor: '#1f2937',
            primaryTextColor: '#f8fafc',
            primaryBorderColor: '#7c3aed',
            lineColor: '#22d3ee',
            secondaryColor: '#111827',
            tertiaryColor: '#ffffff',
            fontFamily: 'Inter, ui-sans-serif, system-ui, sans-serif',
          },
        });
        await Promise.all(
          blocks.map(async (code, index) => {
            const source = code.textContent || '';
            const host = code.closest('.expressive-code') || code.closest('pre');
            if (!host || host.getAttribute('data-mermaid-rendered') === 'true') return;
            host.setAttribute('data-mermaid-rendered', 'true');
            const container = document.createElement('div');
            container.className = 'mermaid-diagram';
            try {
              const { svg } = await mermaid.render(`mermaid-${index}-${Date.now()}`, source);
              container.innerHTML = svg;
              host.replaceWith(container);
            } catch (error) {
              container.classList.add('mermaid-error');
              container.textContent = `Mermaid render failed: ${error instanceof Error ? error.message : String(error)}`;
              host.replaceWith(container);
            }
          }),
        );
      };

      window.addEventListener('DOMContentLoaded', renderMermaid);
    </script>
    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark light;
    --bg: #090a12;
    --bg-soft: #111827;
    --paper: rgba(17, 24, 39, 0.68);
    --paper-strong: rgba(15, 23, 42, 0.86);
    --surface: rgba(255, 255, 255, 0.07);
    --surface-soft: rgba(255, 255, 255, 0.045);
    --text: #f8fafc;
    --muted: #a7b0c2;
    --soft: #7d89a0;
    --line: rgba(255, 255, 255, 0.13);
    --line-strong: rgba(255, 255, 255, 0.24);
    --accent: #22d3ee;
    --accent-strong: #a78bfa;
    --accent-soft: rgba(34, 211, 238, 0.14);
    --rose: #fb7185;
    --amber: #fbbf24;
    --green: #34d399;
    --blue: #60a5fa;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    overflow-x: clip;
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--text);
    line-height: 1.72;
    background:
      radial-gradient(circle at 18% 12%, rgba(124, 58, 237, 0.2), transparent 28rem),
      radial-gradient(circle at 86% 8%, rgba(34, 211, 238, 0.16), transparent 30rem),
      linear-gradient(180deg, #0a0b15 0%, #101827 48%, #070913 100%);
    animation: page-enter 360ms ease both;
    overflow-x: clip;
  }

  .ambient-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background-image: url("https://api.yppp.net/pc.php");
    background-position: center;
    background-size: cover;
    opacity: 0.1;
    filter: blur(7px) saturate(0.9) contrast(0.85);
    pointer-events: none;
  }

  .ambient-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(8, 10, 20, 0.55), rgba(8, 10, 20, 0.9));
  }

  a {
    color: var(--accent);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.22em;
  }

  img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  main {
    width: min(100% - 32px, 1320px);
    margin: 0 auto;
    padding: 26px 0 72px;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--line);
    background: rgba(9, 10, 18, 0.64);
    backdrop-filter: blur(20px) saturate(1.2);
  }

  .nav {
    width: min(100% - 32px, 1320px);
    min-height: 66px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text);
    font-weight: 850;
    text-decoration: none;
    white-space: nowrap;
  }

  .brand-mark {
    display: inline-grid;
    width: 35px;
    height: 35px;
    place-items: center;
    border: 1px solid rgba(34, 211, 238, 0.42);
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(34, 211, 238, 0.22), rgba(167, 139, 250, 0.22));
    box-shadow: 0 0 30px rgba(34, 211, 238, 0.18);
  }

  .nav-links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 6px;
    flex-wrap: wrap;
  }

  .nav-links a {
    min-height: 34px;
    padding: 6px 10px;
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.92rem;
    text-decoration: none;
    transition: background 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .nav-links a:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-1px);
  }

  .site-footer {
    width: min(100% - 32px, 1320px);
    margin: 0 auto;
    padding: 26px 0 38px;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.92rem;
  }

  .glass-panel,
  .post-card,
  .stat-card,
  .activity-card,
  .category-card,
  .portfolio-card,
  .note-card,
  .search-box,
  .article-header,
  .article-content,
  .article-sidebar,
  .comments-panel,
  .toc-panel,
  .pager-card,
  .mdx-card-grid > *,
  .link-card {
    border: 1px solid var(--line);
    background: var(--paper);
    backdrop-filter: blur(20px) saturate(1.12);
    box-shadow: 0 22px 60px rgba(0, 0, 0, 0.22);
  }

  .page-kicker {
    margin: 0 0 8px;
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 780;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .page-title {
    margin: 0;
    color: var(--text);
    font-size: clamp(2rem, 7vw, 4.8rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .page-intro {
    max-width: 760px;
    margin: 14px 0 0;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.1rem);
  }

  .button-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 15px;
    border: 1px solid rgba(34, 211, 238, 0.36);
    border-radius: 999px;
    background: rgba(34, 211, 238, 0.16);
    color: var(--text);
    font-weight: 740;
    text-decoration: none;
  }

  .button-link.secondary {
    border-color: var(--line);
    background: rgba(255, 255, 255, 0.06);
    color: var(--muted);
  }

  .home-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 18px;
    align-items: start;
  }

  .home-hero {
    margin-bottom: 16px;
    padding: clamp(22px, 4vw, 36px);
    border: 1px solid var(--line);
    border-radius: 24px;
    background:
      linear-gradient(135deg, rgba(34, 211, 238, 0.13), transparent 36%),
      linear-gradient(315deg, rgba(167, 139, 250, 0.16), transparent 42%),
      var(--paper-strong);
    backdrop-filter: blur(22px) saturate(1.15);
    overflow: hidden;
  }

  .hero-actions,
  .post-taxonomy {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .home-sidebar {
    position: sticky;
    top: 88px;
    display: grid;
    gap: 14px;
  }

  .stat-card,
  .activity-card {
    border-radius: 18px;
    padding: 17px;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 14px;
  }

  .stat-grid div {
    padding: 12px;
    border-radius: 14px;
    background: var(--surface-soft);
  }

  .stat-grid strong {
    display: block;
    font-size: 1.3rem;
  }

  .stat-grid span {
    color: var(--muted);
    font-size: 0.82rem;
  }

  .activity-list,
  .tag-list,
  .archive-list,
  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .activity-list {
    display: grid;
    gap: 10px;
    margin-top: 12px;
  }

  .activity-list a {
    color: var(--text);
    font-weight: 720;
    text-decoration: none;
  }

  .feed-toolbar,
  .section-heading {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: end;
    margin: 0 0 16px;
  }

  .section-heading.compact {
    margin-bottom: 12px;
  }

  .section-heading h1,
  .section-heading h2,
  .feed-toolbar h2 {
    margin: 0;
  }

  .section-heading p,
  .feed-toolbar p {
    max-width: 540px;
    margin: 0;
    color: var(--muted);
  }

  .masonry-feed {
    columns: 2 290px;
    column-gap: 14px;
  }

  .post-grid,
  .portfolio-grid,
  .category-grid,
  .notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 14px;
  }

  .post-card {
    display: inline-block;
    width: 100%;
    margin: 0 0 14px;
    border-radius: 20px;
    overflow: hidden;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .post-grid .post-card {
    display: block;
    margin: 0;
  }

  .post-card:hover {
    transform: translateY(-3px);
    border-color: rgba(34, 211, 238, 0.34);
    box-shadow: 0 30px 70px rgba(0, 0, 0, 0.28);
  }

  .post-card-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .post-card-body,
  .category-card,
  .portfolio-card,
  .note-card {
    padding: 17px;
  }

  .post-card h2 {
    margin: 8px 0 9px;
    font-size: 1.24rem;
    line-height: 1.28;
  }

  .post-card h2 a,
  .category-card,
  .portfolio-card a,
  .note-card a {
    color: var(--text);
    text-decoration: none;
  }

  .post-card p,
  .category-card p,
  .portfolio-card p,
  .note-card p {
    margin: 0;
    color: var(--muted);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 9px;
    color: var(--soft);
    font-size: 0.84rem;
  }

  .post-meta a,
  .category-pill,
  .tag-list a {
    display: inline-flex;
    align-items: center;
    min-height: 27px;
    padding: 0 9px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.055);
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 12px;
  }

  .category-card,
  .portfolio-card,
  .note-card {
    border-radius: 18px;
  }

  .archive-year {
    margin: 0 0 20px;
  }

  .archive-year h2 {
    margin: 0 0 10px;
  }

  .archive-list {
    display: grid;
    gap: 10px;
  }

  .archive-list a {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 12px;
    align-items: center;
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--surface-soft);
    color: var(--text);
    text-decoration: none;
  }

  .article-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 286px;
    gap: 18px;
    align-items: start;
  }

  .article-header,
  .article-content,
  .article-sidebar,
  .comments-panel,
  .toc-panel,
  .pager-card {
    border-radius: 22px;
  }

  .article-header {
    margin-bottom: 16px;
    padding: clamp(22px, 4vw, 38px);
  }

  .article-cover {
    width: 100%;
    max-height: 460px;
    object-fit: cover;
    margin-top: 22px;
    border-radius: 18px;
  }

  .article-content {
    padding: clamp(20px, 4vw, 42px);
    overflow: hidden;
  }

  .article-content > :first-child {
    margin-top: 0;
  }

  .article-content > :last-child {
    margin-bottom: 0;
  }

  .article-content h2,
  .article-content h3 {
    scroll-margin-top: 90px;
    line-height: 1.26;
    margin-top: 2em;
  }

  .article-content p,
  .article-content li {
    color: #dbe3ef;
  }

  .article-content table {
    width: 100%;
    border-collapse: collapse;
    display: block;
    overflow-x: auto;
  }

  .article-content th,
  .article-content td {
    border: 1px solid var(--line);
    padding: 10px 12px;
  }

  .article-content th {
    background: rgba(34, 211, 238, 0.12);
  }

  .article-sidebar {
    position: sticky;
    top: 88px;
    padding: 16px;
  }

  .article-sidebar p,
  .toc-panel p {
    margin: 0 0 12px;
    color: var(--muted);
  }

  .toc-list {
    display: grid;
    gap: 8px;
  }

  .toc-list a {
    color: var(--muted);
    text-decoration: none;
  }

  .toc-list .depth-3 {
    padding-left: 14px;
    font-size: 0.92rem;
  }

  .article-pager {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .pager-card {
    padding: 16px;
    color: var(--text);
    text-decoration: none;
  }

  .comments-panel {
    margin-top: 16px;
    padding: 18px;
  }

  .search-shell {
    max-width: 920px;
    margin: 0 auto;
  }

  .search-box {
    margin-top: 20px;
    border-radius: 22px;
    padding: 18px;
  }

  .search-box .pagefind-ui {
    --pagefind-ui-scale: 0.92;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: var(--line);
    --pagefind-ui-border-radius: 12px;
    --pagefind-ui-font: inherit;
  }

  .empty-state {
    padding: 20px;
    border: 1px dashed var(--line-strong);
    border-radius: 18px;
    color: var(--muted);
    background: var(--surface-soft);
  }

  .expressive-code {
    margin: 1.35rem 0;
  }

  .expressive-code .frame {
    overflow: hidden;
  }

  .expressive-code .header::before {
    content: "";
    display: inline-block;
    width: 42px;
    height: 12px;
    margin-left: 12px;
    background:
      radial-gradient(circle at 6px 6px, #ff5f56 0 5px, transparent 5.5px),
      radial-gradient(circle at 21px 6px, #ffbd2e 0 5px, transparent 5.5px),
      radial-gradient(circle at 36px 6px, #27c93f 0 5px, transparent 5.5px);
  }

  .callout {
    margin: 1.25rem 0;
    padding: 15px 16px;
    border: 1px solid var(--line);
    border-left: 4px solid var(--accent);
    border-radius: 16px;
    background: rgba(15, 23, 42, 0.66);
  }

  .callout-title {
    margin: 0 0 6px;
    color: var(--text);
    font-weight: 820;
  }

  .callout-body > :first-child {
    margin-top: 0;
  }

  .callout-body > :last-child {
    margin-bottom: 0;
  }

  .callout-info { border-left-color: var(--blue); }
  .callout-note { border-left-color: var(--accent); }
  .callout-tip,
  .callout-success { border-left-color: var(--green); }
  .callout-warning { border-left-color: var(--amber); }
  .callout-danger { border-left-color: var(--rose); }

  .content-details {
    margin: 1.25rem 0;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(15, 23, 42, 0.66);
    overflow: hidden;
  }

  .content-details summary {
    cursor: pointer;
    padding: 13px 16px;
    color: var(--text);
    font-weight: 780;
  }

  .content-details > div,
  .content-details > :not(summary) {
    padding: 0 16px 14px;
  }

  .spoiler-text {
    border-radius: 8px;
    padding: 0 4px;
    filter: blur(5px);
    background: rgba(34, 211, 238, 0.16);
    cursor: pointer;
    transition: filter 160ms ease, background 160ms ease;
  }

  .spoiler-text:hover,
  .spoiler-text:focus,
  .spoiler-text.is-revealed {
    filter: blur(0);
    background: rgba(34, 211, 238, 0.08);
  }

  .content-columns,
  .mdx-card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin: 1.25rem 0;
  }

  .content-columns > div,
  .mdx-card-grid > *,
  .content-timeline,
  .content-gallery,
  .mdx-figure,
  .image-compare {
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(15, 23, 42, 0.58);
    padding: 14px;
  }

  .link-card {
    display: block;
    border-radius: 16px;
    color: var(--text);
    text-decoration: none;
  }

  .link-card span {
    color: var(--accent);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .link-card strong {
    display: block;
    margin-top: 6px;
  }

  .content-timeline {
    display: grid;
    gap: 12px;
    margin: 1.25rem 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 12px;
    padding-left: 12px;
    border-left: 3px solid var(--accent-soft);
  }

  .timeline-item time {
    color: var(--accent);
    font-weight: 800;
  }

  .timeline-item p {
    margin: 4px 0 0;
  }

  .mdx-figure,
  .image-compare,
  .content-gallery {
    margin: 1.3rem 0;
  }

  .mdx-figure img,
  .content-gallery img,
  .image-compare img {
    width: 100%;
    border-radius: 12px;
    object-fit: cover;
  }

  .content-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 10px;
  }

  .content-gallery div {
    display: grid;
    gap: 6px;
  }

  .content-gallery span,
  figcaption {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .content-gallery figcaption {
    grid-column: 1 / -1;
  }

  .image-compare > div {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .mermaid-diagram {
    margin: 1.35rem 0;
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(15, 23, 42, 0.76);
    overflow-x: auto;
  }

  .katex-display {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.5rem 0;
