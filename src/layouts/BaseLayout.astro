---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Astro Blog',
  description = 'A static blog powered by Astro and Sveltia CMS.',
} = Astro.props;

const pageTitle = title === 'Astro Blog' ? title : `${title} | Astro Blog`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="Primary navigation">
        <a class="brand" href="/">Astro Blog</a>
        <div class="nav-links">
          <a href="/">文章</a>
          <a href="/tags/">标签</a>
          <a href="/admin/">CMS</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>Powered by Astro, GitHub, and Sveltia CMS.</span>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #fafaf8;
    --panel: #ffffff;
    --text: #20231f;
    --muted: #62695f;
    --line: #deded8;
    --accent: #2f6f55;
    --accent-strong: #214e3d;
    --accent-soft: #e6f1eb;
    --warning: #9a5b00;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    line-height: 1.65;
  }

  a {
    color: var(--accent);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }

  img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  .site-header {
    border-bottom: 1px solid var(--line);
    background: rgba(250, 250, 248, 0.92);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .nav {
    width: min(100% - 32px, 1040px);
    min-height: 64px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .brand {
    color: var(--text);
    font-weight: 750;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 18px;
    font-size: 0.95rem;
  }

  .nav-links a {
    color: var(--muted);
    text-decoration: none;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  main {
    width: min(100% - 32px, 1040px);
    margin: 0 auto;
    padding: 56px 0 72px;
  }

  .site-footer {
    width: min(100% - 32px, 1040px);
    margin: 0 auto;
    padding: 28px 0 40px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.9rem;
  }

  .page-kicker {
    margin: 0 0 8px;
    color: var(--accent-strong);
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    font-size: 0.78rem;
  }

  .page-title {
    margin: 0;
    max-width: 780px;
    font-size: clamp(2.25rem, 8vw, 4.75rem);
    line-height: 0.98;
  }

  .page-intro {
    margin: 18px 0 0;
    max-width: 680px;
    color: var(--muted);
    font-size: 1.1rem;
  }

  .post-grid {
    margin-top: 44px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 18px;
  }

  .post-card {
    min-height: 100%;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
  }

  .post-card-cover {
    aspect-ratio: 16 / 9;
    width: 100%;
    object-fit: cover;
    border-bottom: 1px solid var(--line);
  }

  .post-card-body {
    padding: 20px;
    display: flex;
    flex: 1;
    flex-direction: column;
  }

  .post-meta {
    margin: 0 0 10px;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .post-card h2 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.2;
  }

  .post-card h2 a {
    color: var(--text);
    text-decoration: none;
  }

  .post-card h2 a:hover {
    color: var(--accent);
  }

  .post-card p {
    margin: 12px 0 0;
    color: var(--muted);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
  }

  .tag-list a,
  .tag-pill {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    border: 1px solid #bfd8ca;
    border-radius: 999px;
    padding: 4px 12px;
    background: var(--accent-soft);
    color: var(--accent-strong);
    font-size: 0.88rem;
    text-decoration: none;
  }

  .article-header {
    max-width: 760px;
  }

  .article-cover {
    margin: 36px 0;
    width: 100%;
    max-height: 520px;
    object-fit: cover;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .article-content {
    max-width: 760px;
    font-size: 1.05rem;
  }

  .article-content h2,
  .article-content h3 {
    line-height: 1.2;
    margin-top: 2.1em;
  }

  .article-content p,
  .article-content ul,
  .article-content ol,
  .article-content blockquote {
    margin: 1.1em 0;
  }

  .article-content pre {
    overflow-x: auto;
    border-radius: 8px;
    padding: 18px;
  }

  .article-content code {
    font-size: 0.92em;
  }

  .article-content blockquote {
    border-left: 4px solid var(--accent);
    padding-left: 18px;
    color: var(--muted);
  }

  .empty-state {
    margin-top: 44px;
    border: 1px dashed var(--line);
    border-radius: 8px;
    padding: 28px;
    background: var(--panel);
    color: var(--muted);
  }

  .draft-note {
    display: inline-flex;
    margin-top: 16px;
    border: 1px solid #e3c37d;
    border-radius: 8px;
    padding: 8px 12px;
    color: var(--warning);
    background: #fff8e8;
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .nav {
      min-height: 76px;
      align-items: flex-start;
      flex-direction: column;
      justify-content: center;
      gap: 6px;
    }

    .nav-links {
      width: 100%;
      justify-content: space-between;
      gap: 12px;
    }

    main {
      padding-top: 40px;
    }
  }
</style>
