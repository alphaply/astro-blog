---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title?: string;
  description?: string;
}

const siteName = "Alpha's Blog";

const {
  title = siteName,
  description = 'Alpha 的技术手账，记录工程实践、工具链和长期学习笔记。',
} = Astro.props;

const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="anime-bg" aria-hidden="true"></div>
    <header class="site-header">
      <nav class="nav" aria-label="Primary navigation">
        <a class="brand" href="/">
          <span class="brand-mark">A</span>
          <span>{siteName}</span>
        </a>
        <div class="nav-links">
          <a href="/">文章</a>
          <a href="/tags/">标签</a>
          <a href="/search/">搜索</a>
          <a href="/admin/">CMS</a>
        </div>
      </nav>
    </header>
    <main data-pagefind-body>
      <slot />
    </main>
    <footer class="site-footer">
      <span>Alpha's Blog · Astro / MDX / GitHub / Sveltia CMS</span>
      <a href="/admin/">进入后台</a>
    </footer>
    <script is:inline>
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const reveal = target.closest('.blur-reveal');
        if (reveal) {
          reveal.classList.toggle('is-revealed');
        }
      });
    </script>
    <script is:inline>
      const loadMermaid = () =>
        import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');

      const renderMermaid = async () => {
        const blocks = [...document.querySelectorAll('.expressive-code pre code.language-mermaid, pre code.language-mermaid')];
        if (!blocks.length) return;
        const { default: mermaid } = await loadMermaid();
        mermaid.initialize({
          startOnLoad: false,
          securityLevel: 'strict',
          theme: 'base',
          themeVariables: {
            primaryColor: '#dfeee6',
            primaryTextColor: '#171c18',
            primaryBorderColor: '#bdd3c6',
            lineColor: '#256f55',
            secondaryColor: '#f7f8f4',
            tertiaryColor: '#ffffff',
            fontFamily: 'Inter, ui-sans-serif, system-ui, sans-serif',
          },
        });
        await Promise.all(
          blocks.map(async (code, index) => {
            const source = code.textContent || '';
            const host = code.closest('.expressive-code') || code.closest('pre');
            if (!host || host.getAttribute('data-mermaid-rendered') === 'true') return;
            host.setAttribute('data-mermaid-rendered', 'true');
            const container = document.createElement('div');
            container.className = 'mermaid-diagram';
            try {
              const { svg } = await mermaid.render(`mermaid-${index}-${Date.now()}`, source);
              container.innerHTML = svg;
              host.replaceWith(container);
            } catch (error) {
              container.classList.add('mermaid-error');
              container.textContent = `Mermaid render failed: ${error instanceof Error ? error.message : String(error)}`;
              host.replaceWith(container);
            }
          }),
        );
      };

      window.addEventListener('DOMContentLoaded', renderMermaid);
    </script>
    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f7f8f4;
    --glass: rgba(255, 255, 255, 0.66);
    --glass-strong: rgba(255, 255, 255, 0.82);
    --surface: #ffffff;
    --surface-muted: rgba(238, 242, 233, 0.82);
    --text: #171c18;
    --muted: #657064;
    --soft: #8a9387;
    --line: rgba(217, 223, 212, 0.84);
    --line-strong: rgba(189, 200, 186, 0.9);
    --accent: #256f55;
    --accent-strong: #164936;
    --accent-soft: #dfeee6;
    --ink: #111713;
    --code-bg: #111713;
    --warning: #9a5b00;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--text);
    line-height: 1.65;
    animation: page-enter 360ms ease both;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(90deg, rgba(23, 28, 24, 0.045) 1px, transparent 1px),
      linear-gradient(rgba(23, 28, 24, 0.04) 1px, transparent 1px),
      linear-gradient(180deg, rgba(247, 248, 244, 0.7), rgba(247, 248, 244, 0.92));
    background-size: 48px 48px, 48px 48px, auto;
    pointer-events: none;
  }

  .anime-bg {
    position: fixed;
    inset: 0;
    z-index: -3;
    background-image: url("https://api.yppp.net/pc.php");
    background-position: center;
    background-size: cover;
    filter: saturate(0.9) contrast(0.96);
  }

  a {
    color: var(--accent);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.22em;
  }

  img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid rgba(23, 28, 24, 0.1);
    background: rgba(247, 248, 244, 0.62);
    backdrop-filter: blur(18px) saturate(1.12);
  }

  .nav {
    width: min(100% - 32px, 1120px);
    min-height: 68px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text);
    font-weight: 780;
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    width: 32px;
    height: 32px;
    place-items: center;
    border: 1px solid var(--line-strong);
    border-radius: 7px;
    background: var(--ink);
    color: #f8fff9;
    font-size: 0.9rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.94rem;
  }

  .nav-links a {
    min-height: 34px;
    display: inline-flex;
    align-items: center;
    border-radius: 7px;
    padding: 4px 10px;
    color: var(--muted);
    text-decoration: none;
  }

  .nav-links a:hover {
    background: rgba(255, 255, 255, 0.52);
    color: var(--text);
  }

  main {
    width: min(100% - 32px, 1120px);
    margin: 0 auto;
    padding: 54px 0 80px;
  }

  .site-footer {
    width: min(100% - 32px, 1120px);
    margin: 0 auto;
    padding: 28px 0 42px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.9rem;
  }

  .site-footer a {
    color: var(--muted);
    text-decoration: none;
  }

  .page-kicker {
    margin: 0 0 10px;
    color: var(--accent-strong);
    font-weight: 780;
    letter-spacing: 0;
    text-transform: uppercase;
    font-size: 0.78rem;
  }

  .page-title {
    margin: 0;
    max-width: 820px;
    font-size: clamp(2.4rem, 8vw, 5rem);
    line-height: 0.98;
  }

  .page-intro {
    margin: 18px 0 0;
    max-width: 690px;
    color: var(--muted);
    font-size: 1.1rem;
  }

  .home-hero {
    min-height: 420px;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
    align-items: center;
    gap: 32px;
  }

  .hero-copy {
    padding: 22px 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 26px;
  }

  .button-link {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    border-radius: 7px;
    padding: 8px 14px;
    background: var(--ink);
    color: #f8fff9;
    font-weight: 700;
    text-decoration: none;
  }

  .button-link.secondary {
    border-color: var(--line-strong);
    background: rgba(255, 255, 255, 0.5);
    color: var(--text);
  }

  .workbench-panel,
  .search-box,
  .post-card,
  .post-feature,
  .post-row,
  .tag-index a,
  .article-sidebar {
    border: 1px solid var(--line-strong);
    background: var(--glass);
    backdrop-filter: blur(18px) saturate(1.12);
    box-shadow: 0 18px 50px rgba(23, 28, 24, 0.08);
  }

  .workbench-panel,
  .search-box,
  .post-feature,
  .tag-index a {
    border-radius: 10px;
    overflow: hidden;
  }

  .panel-bar {
    min-height: 42px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-bottom: 1px solid var(--line);
    padding: 0 14px;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .panel-dots {
    display: inline-flex;
    gap: 6px;
  }

  .panel-dots span {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--line-strong);
  }

  .panel-content {
    padding: 18px;
  }

  .status-list {
    display: grid;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .status-list li {
    display: grid;
    grid-template-columns: 98px 1fr;
    gap: 14px;
    border-bottom: 1px solid var(--line);
    padding-bottom: 12px;
  }

  .status-list li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .status-label {
    color: var(--soft);
    font-size: 0.84rem;
  }

  .status-value {
    color: var(--text);
    font-weight: 700;
  }

  .section-heading {
    margin-top: 58px;
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
    border-top: 1px solid var(--line);
    padding-top: 26px;
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.55rem, 4vw, 2.4rem);
    line-height: 1.08;
  }

  .section-heading p {
    margin: 8px 0 0;
    max-width: 520px;
    color: var(--muted);
  }

  .post-grid {
    margin-top: 22px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
    gap: 16px;
  }

  .post-card {
    min-height: 100%;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 10px;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .post-card:hover {
    transform: translateY(-2px);
    border-color: var(--line-strong);
    box-shadow: 0 16px 36px rgba(23, 28, 24, 0.12);
  }

  .post-card-cover {
    aspect-ratio: 16 / 9;
    width: 100%;
    object-fit: cover;
    border-bottom: 1px solid var(--line);
  }

  .post-card-body {
    padding: 20px;
    display: flex;
    flex: 1;
    flex-direction: column;
  }

  .post-meta {
    margin: 0 0 10px;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .post-card h2,
  .post-card h3 {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.2;
  }

  .post-card h2 a,
  .post-card h3 a {
    color: var(--text);
    text-decoration: none;
  }

  .post-card h2 a:hover,
  .post-card h3 a:hover {
    color: var(--accent);
  }

  .post-card p {
    margin: 12px 0 0;
    color: var(--muted);
  }

  .post-feature {
    margin-top: 24px;
  }

  .post-feature-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.54fr);
    min-height: 280px;
  }

  .post-feature-copy {
    padding: clamp(24px, 5vw, 38px);
  }

  .post-feature-aside {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border-left: 1px solid var(--line);
    background: rgba(238, 242, 233, 0.52);
    padding: 22px;
  }

  .post-feature h2 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1;
  }

  .post-feature h2 a {
    color: var(--text);
    text-decoration: none;
  }

  .post-list {
    margin-top: 20px;
    display: grid;
    gap: 10px;
  }

  .post-row {
    display: grid;
    grid-template-columns: 124px 1fr auto;
    gap: 16px;
    align-items: center;
    border-radius: 10px;
    padding: 15px 16px;
  }

  .post-row a {
    color: var(--text);
    font-weight: 750;
    text-decoration: none;
  }

  .post-row p {
    margin: 4px 0 0;
    color: var(--muted);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
  }

  .tag-list a,
  .tag-pill {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    border: 1px solid #bdd3c6;
    border-radius: 999px;
    padding: 4px 12px;
    background: rgba(223, 238, 230, 0.8);
    color: var(--accent-strong);
    font-size: 0.88rem;
    text-decoration: none;
  }

  .tag-index {
    margin-top: 32px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 220px), 1fr));
    gap: 12px;
  }

  .tag-index a {
    display: flex;
    min-height: 82px;
    align-items: center;
    justify-content: space-between;
    padding: 18px;
    color: var(--text);
    font-weight: 750;
    text-decoration: none;
  }

  .tag-index span {
    color: var(--muted);
    font-weight: 600;
  }

  .article-shell {
    display: grid;
    grid-template-columns: minmax(0, 760px) minmax(220px, 1fr);
    gap: 42px;
    align-items: start;
  }

  .article-header {
    max-width: 760px;
  }

  .article-sidebar {
    position: sticky;
    top: 96px;
    border-radius: 10px;
    padding: 18px;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .article-sidebar p {
    margin: 0 0 12px;
  }

  .article-cover {
    margin: 34px 0;
    width: 100%;
    max-height: 520px;
    object-fit: cover;
    border: 1px solid var(--line);
    border-radius: 10px;
  }

  .article-content {
    max-width: 760px;
    font-size: 1.06rem;
  }

  .article-content h2,
  .article-content h3 {
    line-height: 1.2;
    margin-top: 2.1em;
  }

  .article-content p,
  .article-content ul,
  .article-content ol,
  .article-content blockquote,
  .article-content table {
    margin: 1.1em 0;
  }

  .article-content pre {
    overflow-x: auto;
  }

  .article-content code {
    font-size: 0.92em;
  }

  .article-content table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--line-strong);
    border-radius: 10px;
    overflow: hidden;
    background: var(--glass);
  }

  .article-content th,
  .article-content td {
    border: 1px solid var(--line);
    padding: 10px 12px;
    text-align: left;
  }

  .article-content th {
    background: rgba(223, 238, 230, 0.72);
  }

  .article-content blockquote {
    border-left: 4px solid var(--accent);
    padding-left: 18px;
    color: var(--muted);
  }

  .article-content .katex-display {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.45rem 0;
  }

  .expressive-code {
    margin: 1.45em 0;
  }

  .expressive-code .frame {
    border-radius: 12px !important;
    box-shadow: 0 20px 50px rgba(17, 23, 19, 0.16) !important;
  }

  .expressive-code .header::before {
    content: "";
    width: 42px;
    height: 12px;
    display: inline-block;
    margin-right: 10px;
    background:
      radial-gradient(circle at 6px 6px, #ff5f57 0 5px, transparent 5.5px),
      radial-gradient(circle at 21px 6px, #febc2e 0 5px, transparent 5.5px),
      radial-gradient(circle at 36px 6px, #28c840 0 5px, transparent 5.5px);
  }

  .article-content .callout,
  .article-content .content-details,
  .article-content .content-columns > div,
  .article-content .content-timeline,
  .article-content .content-plan,
  .mermaid-diagram {
    border: 1px solid rgba(201, 216, 208, 0.9);
    border-radius: 10px;
    background: var(--glass);
    backdrop-filter: blur(16px) saturate(1.1);
  }

  .article-content .callout {
    margin: 1.4em 0;
    border-left: 4px solid var(--accent);
    padding: 14px 16px;
  }

  .article-content .callout-note {
    border-left-color: #5865f2;
    background: rgba(241, 243, 255, 0.82);
  }

  .article-content .callout-tip,
  .article-content .callout-success {
    border-left-color: #2f8f5b;
    background: rgba(240, 251, 244, 0.82);
  }

  .article-content .callout-warning {
    border-left-color: #b87500;
    background: rgba(255, 248, 232, 0.86);
  }

  .article-content .callout-danger {
    border-left-color: #c73e3a;
    background: rgba(255, 241, 240, 0.86);
  }

  .article-content .callout-title {
    margin: 0 0 0.35em;
    color: var(--text);
    font-weight: 750;
  }

  .article-content .callout p:last-child {
    margin-bottom: 0;
  }

  .article-content .content-details {
    margin: 1.35em 0;
    overflow: hidden;
  }

  .article-content .content-details summary {
    cursor: pointer;
    padding: 13px 16px;
    color: var(--text);
    font-weight: 750;
  }

  .article-content .content-details > :not(summary) {
    margin: 0;
    padding: 0 16px 14px;
  }

  .article-content .blur-reveal {
    cursor: pointer;
    border-radius: 6px;
    padding: 0.05em 0.24em;
    background: rgba(37, 111, 85, 0.12);
    filter: blur(5px);
    transition:
      filter 160ms ease,
      background 160ms ease;
  }

  .article-content .blur-reveal:hover,
  .article-content .blur-reveal:focus,
  .article-content .blur-reveal.is-revealed {
    filter: blur(0);
    background: rgba(37, 111, 85, 0.18);
    outline: none;
  }

  .article-content .content-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    margin: 1.6em 0;
  }

  .article-content .content-columns > div {
    padding: 16px;
  }

  .article-content .content-timeline {
    margin: 1.5em 0;
    padding: 16px;
  }

  .article-content .timeline-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 14px;
    border-left: 2px solid var(--line-strong);
    padding: 0 0 16px 16px;
    position: relative;
  }

  .article-content .timeline-item::before {
    content: "";
    position: absolute;
    left: -6px;
    top: 0.52em;
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--accent);
  }

  .article-content .timeline-item time {
    color: var(--accent-strong);
    font-weight: 800;
  }

  .article-content .content-plan {
    margin: 1.5em 0;
    padding: 14px;
    display: grid;
    gap: 8px;
  }

  .article-content .content-plan > div {
    border-radius: 8px;
    padding: 10px 12px;
    background: rgba(255, 255, 255, 0.62);
  }

  .article-content .content-plan [data-status]::before {
    display: inline-flex;
    min-width: 58px;
    margin-right: 8px;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 850;
  }

  .article-content .content-plan [data-status="todo"]::before {
    content: "TODO";
  }

  .article-content .content-plan [data-status="doing"]::before {
    content: "DOING";
  }

  .article-content .content-plan [data-status="done"]::before {
    content: "DONE";
  }

  .article-content .content-gallery {
    margin: 1.8em 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .article-content .content-gallery img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 1px solid var(--line);
    border-radius: 10px;
  }

  .article-content .content-gallery figcaption {
    grid-column: 1 / -1;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .mermaid-diagram {
    margin: 1.5em 0;
    padding: 18px;
    overflow-x: auto;
  }

  .mermaid-diagram svg {
    max-width: 100%;
    height: auto;
  }

  .mermaid-error {
    color: #9a231f;
    white-space: pre-wrap;
  }

  .search-shell {
    max-width: 860px;
  }

  .search-box {
    margin-top: 30px;
    padding: 18px;
  }

  .search-box .pagefind-ui {
    --pagefind-ui-scale: 0.92;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text);
