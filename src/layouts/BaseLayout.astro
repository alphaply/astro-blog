---
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title?: string;
  description?: string;
}

const siteName = 'Alpha Blog';
const {
  title = siteName,
  description = 'Alpha Blog：生活、知识与作品记录。',
} = Astro.props;

const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="ambient-bg" aria-hidden="true"></div>
    <header class="site-header">
      <nav class="nav" aria-label="主导航">
        <a class="brand" href="/">
          <span class="brand-mark">A</span>
          <span>{siteName}</span>
        </a>
        <div class="nav-links">
          <a href="/">文章</a>
          <a href="/archives/">归档</a>
          <a href="/notes/">说说</a>
          <a href="/categories/">分类</a>
          <a href="/tags/">标签</a>
          <a href="/portfolio/">作品</a>
          <a href="/guestbook/">留言</a>
          <a href="/about/">关于</a>
          <a href="/search/">搜索</a>
        </div>
      </nav>
    </header>
    <main data-pagefind-body>
      <slot />
    </main>
    <footer class="site-footer">
      <span>Alpha Blog · MDX powered static notes</span>
      <a href="/about/">关于本站</a>
    </footer>
    <script is:inline>
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const reveal = target.closest('.spoiler-text');
        if (reveal) reveal.classList.toggle('is-revealed');
      });
    </script>
    <script is:inline>
      const loadMermaid = () =>
        import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');

      const renderMermaid = async () => {
        const blocks = [...document.querySelectorAll('.expressive-code pre code.language-mermaid, pre code.language-mermaid')];
        if (!blocks.length) return;
        const { default: mermaid } = await loadMermaid();
        mermaid.initialize({
          startOnLoad: false,
          securityLevel: 'strict',
          theme: 'base',
          themeVariables: {
            primaryColor: '#e8f7f2',
            primaryTextColor: '#25312d',
            primaryBorderColor: '#8fcfbd',
            lineColor: '#6f9f93',
            secondaryColor: '#f7eef5',
            tertiaryColor: '#fffaf4',
            fontFamily: 'Inter, ui-sans-serif, system-ui, sans-serif',
          },
        });
        await Promise.all(
          blocks.map(async (code, index) => {
            const source = code.textContent || '';
            const host = code.closest('.expressive-code') || code.closest('pre');
            if (!host || host.getAttribute('data-mermaid-rendered') === 'true') return;
            host.setAttribute('data-mermaid-rendered', 'true');
            const container = document.createElement('div');
            container.className = 'mermaid-diagram';
            try {
              const { svg } = await mermaid.render(`mermaid-${index}-${Date.now()}`, source);
              container.innerHTML = svg;
              host.replaceWith(container);
            } catch (error) {
              container.classList.add('mermaid-error');
              container.textContent = `Mermaid render failed: ${error instanceof Error ? error.message : String(error)}`;
              host.replaceWith(container);
            }
          }),
        );
      };

      window.addEventListener('DOMContentLoaded', renderMermaid);
    </script>
    <Analytics />
    <SpeedInsights />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --bg: #f7f8f5;
    --paper: rgba(255, 255, 255, 0.78);
    --paper-strong: rgba(255, 255, 255, 0.92);
    --surface: rgba(255, 255, 255, 0.64);
    --surface-soft: rgba(109, 151, 140, 0.08);
    --text: #23312d;
    --muted: #66766f;
    --soft: #87958e;
    --line: rgba(61, 83, 76, 0.13);
    --line-strong: rgba(61, 83, 76, 0.22);
    --accent: #4f9f8b;
    --accent-strong: #2f7466;
    --accent-soft: rgba(91, 176, 154, 0.16);
    --pink: #d989a5;
    --rose: #d9657f;
    --amber: #c7923f;
    --green: #54a878;
    --blue: #6e95c9;
    --radius: 22px;
    --shadow: 0 18px 48px rgba(79, 103, 96, 0.13);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    overflow-x: clip;
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--text);
    line-height: 1.72;
    background:
      radial-gradient(circle at 12% 4%, rgba(214, 238, 231, 0.86), transparent 30rem),
      radial-gradient(circle at 86% 10%, rgba(248, 218, 231, 0.62), transparent 28rem),
      linear-gradient(180deg, #fbfbf7 0%, #f1f6f2 52%, #f8f3f7 100%);
    animation: page-enter 340ms ease both;
    overflow-x: clip;
  }

  .ambient-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background-image: url("https://api.yppp.net/pc.php");
    background-position: center;
    background-size: cover;
    opacity: 0.06;
    filter: blur(6px) saturate(0.74) contrast(0.92);
    pointer-events: none;
  }

  .ambient-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(251, 251, 247, 0.8), rgba(247, 248, 245, 0.94));
  }

  a {
    color: var(--accent-strong);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.22em;
  }

  img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  main {
    width: min(100% - 32px, 1280px);
    margin: 0 auto;
    padding: 24px 0 72px;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid rgba(255, 255, 255, 0.62);
    background: rgba(248, 250, 247, 0.76);
    backdrop-filter: blur(20px) saturate(1.16);
    box-shadow: 0 10px 34px rgba(79, 103, 96, 0.08);
  }

  .nav {
    width: min(100% - 32px, 1280px);
    min-height: 64px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text);
    font-weight: 850;
    text-decoration: none;
    white-space: nowrap;
  }

  .brand-mark {
    display: inline-grid;
    width: 36px;
    height: 36px;
    place-items: center;
    border: 1px solid rgba(79, 159, 139, 0.34);
    border-radius: 14px;
    background: linear-gradient(135deg, #effaf5, #fdeff5);
    color: var(--accent-strong);
    box-shadow: 0 10px 24px rgba(79, 159, 139, 0.14);
  }

  .nav-links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    flex-wrap: wrap;
  }

  .nav-links a {
    min-height: 34px;
    padding: 6px 10px;
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 650;
    text-decoration: none;
    transition: background 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .nav-links a:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.72);
    transform: translateY(-1px);
  }

  .site-footer {
    width: min(100% - 32px, 1280px);
    margin: 0 auto;
    padding: 26px 0 38px;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.92rem;
  }

  .glass-panel,
  .post-card,
  .stat-card,
  .activity-card,
  .category-card,
  .portfolio-card,
  .note-card,
  .search-box,
  .article-header,
  .article-content,
  .article-sidebar,
  .comments-panel,
  .toc-panel,
  .pager-card,
  .about-panel,
  .mdx-card-grid > *,
  .link-card {
    border: 1px solid var(--line);
    background: var(--paper);
    backdrop-filter: blur(18px) saturate(1.08);
    box-shadow: var(--shadow);
  }

  .page-kicker {
    margin: 0 0 8px;
    color: var(--accent-strong);
    font-size: 0.75rem;
    font-weight: 820;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .page-title {
    margin: 0;
    color: var(--text);
    font-size: clamp(2rem, 6vw, 4.4rem);
    line-height: 1.04;
    letter-spacing: 0;
  }

  .page-intro {
    max-width: 740px;
    margin: 14px 0 0;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.08rem);
  }

  .button-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 15px;
    border: 1px solid rgba(79, 159, 139, 0.26);
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(91, 176, 154, 0.18), rgba(217, 137, 165, 0.13));
    color: var(--accent-strong);
    font-weight: 760;
    text-decoration: none;
  }

  .button-link.secondary {
    border-color: var(--line);
    background: rgba(255, 255, 255, 0.62);
    color: var(--muted);
  }

  .home-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 292px;
    gap: 18px;
    align-items: start;
  }

  .home-hero {
    margin-bottom: 16px;
    padding: clamp(22px, 4vw, 34px);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 28px;
    background:
      linear-gradient(135deg, rgba(232, 247, 242, 0.92), transparent 45%),
      linear-gradient(315deg, rgba(252, 236, 244, 0.9), transparent 46%),
      var(--paper-strong);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .hero-actions,
  .post-taxonomy {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .home-sidebar {
    position: sticky;
    top: 86px;
    display: grid;
    gap: 14px;
  }

  .stat-card,
  .activity-card,
  .about-panel {
    border-radius: var(--radius);
    padding: 17px;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 14px;
  }

  .stat-grid div {
    padding: 12px;
    border-radius: 16px;
    background: var(--surface-soft);
  }

  .stat-grid strong {
    display: block;
    font-size: 1.28rem;
  }

  .stat-grid span {
    color: var(--muted);
    font-size: 0.82rem;
  }

  .activity-list,
  .tag-list,
  .archive-list,
  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .activity-list {
    display: grid;
    gap: 10px;
    margin-top: 12px;
  }

  .activity-list li {
    display: flex;
    justify-content: space-between;
    gap: 10px;
  }

  .activity-list a {
    color: var(--text);
    font-weight: 720;
    text-decoration: none;
  }

  .feed-toolbar,
  .section-heading {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: end;
    margin: 0 0 16px;
  }

  .section-heading.compact {
    margin-bottom: 12px;
  }

  .section-heading h1,
  .section-heading h2,
  .feed-toolbar h2 {
    margin: 0;
  }

  .section-heading p,
  .feed-toolbar p {
    max-width: 540px;
    margin: 0;
    color: var(--muted);
  }

  .masonry-feed {
    columns: 2 292px;
    column-gap: 14px;
  }

  .post-grid,
  .portfolio-grid,
  .category-grid,
  .notes-grid,
  .about-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 14px;
  }

  .post-card {
    display: inline-block;
    width: 100%;
    margin: 0 0 14px;
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .post-grid .post-card {
    display: block;
    margin: 0;
  }

  .post-card:hover {
    transform: translateY(-3px);
    border-color: rgba(79, 159, 139, 0.28);
    box-shadow: 0 24px 56px rgba(79, 103, 96, 0.16);
  }

  .post-card-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .post-card-body,
  .category-card,
  .portfolio-card,
  .note-card {
    padding: 17px;
  }

  .post-card h2 {
    margin: 8px 0 9px;
    font-size: 1.22rem;
    line-height: 1.3;
  }

  .post-card h2 a,
  .category-card,
  .portfolio-card a,
  .note-card a {
    color: var(--text);
    text-decoration: none;
  }

  .post-card p,
  .category-card p,
  .portfolio-card p,
  .note-card p,
  .about-panel p {
    margin: 0;
    color: var(--muted);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 9px;
    color: var(--soft);
    font-size: 0.84rem;
  }

  .post-meta a,
  .category-pill,
  .tag-list a {
    display: inline-flex;
    align-items: center;
    min-height: 27px;
    padding: 0 9px;
    border: 1px solid rgba(79, 159, 139, 0.18);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.62);
    color: var(--accent-strong);
    font-size: 0.8rem;
    font-weight: 720;
    text-decoration: none;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 12px;
  }

  .category-card,
  .portfolio-card,
  .note-card {
    border-radius: var(--radius);
  }

  .archive-year {
    margin: 0 0 20px;
  }

  .archive-year h2 {
    margin: 0 0 10px;
  }

  .archive-list {
    display: grid;
    gap: 10px;
  }

  .archive-list a {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 12px;
    align-items: center;
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
  }

  .article-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 286px;
    gap: 18px;
    align-items: start;
  }

  .article-header,
  .article-content,
  .article-sidebar,
  .comments-panel,
  .toc-panel,
  .pager-card {
    border-radius: var(--radius);
  }

  .article-header {
    margin-bottom: 16px;
    padding: clamp(22px, 4vw, 38px);
  }

  .article-cover {
    width: 100%;
    max-height: 460px;
    object-fit: cover;
    margin-top: 22px;
    border-radius: 18px;
  }

  .article-content {
    padding: clamp(20px, 4vw, 42px);
    overflow: hidden;
  }

  .article-content > :first-child {
    margin-top: 0;
  }

  .article-content > :last-child {
    margin-bottom: 0;
  }

  .article-content h2,
  .article-content h3 {
    scroll-margin-top: 90px;
    line-height: 1.28;
    margin-top: 2em;
  }

  .article-content p,
  .article-content li {
    color: #36443f;
  }

  .article-content table {
    width: 100%;
    border-collapse: collapse;
    display: block;
    overflow-x: auto;
  }

  .article-content th,
  .article-content td {
    border: 1px solid var(--line);
    padding: 10px 12px;
  }

  .article-content th {
    background: rgba(91, 176, 154, 0.13);
  }

  .article-sidebar {
    position: sticky;
    top: 86px;
    padding: 16px;
  }

  .article-sidebar p,
  .toc-panel p {
    margin: 0 0 12px;
    color: var(--muted);
  }

  .toc-panel {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
    background: transparent;
    box-shadow: none;
    border-left: 0;
    border-right: 0;
    border-bottom: 0;
  }

  .toc-list {
    display: grid;
    gap: 8px;
  }

  .toc-list a {
    color: var(--muted);
    text-decoration: none;
  }

  .toc-list .depth-3 {
    padding-left: 14px;
    font-size: 0.92rem;
  }

  .article-pager {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .pager-card {
    padding: 16px;
    color: var(--text);
    text-decoration: none;
  }

  .comments-panel {
    margin-top: 16px;
    padding: 18px;
  }

  .search-shell {
    max-width: 920px;
    margin: 0 auto;
  }

  .search-box {
    margin-top: 20px;
    border-radius: var(--radius);
    padding: 18px;
  }

  .search-box .pagefind-ui {
    --pagefind-ui-scale: 0.92;
    --pagefind-ui-primary: var(--accent-strong);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: var(--line);
    --pagefind-ui-border-radius: 14px;
    --pagefind-ui-font: inherit;
  }

  .empty-state {
    padding: 20px;
    border: 1px dashed var(--line-strong);
    border-radius: 18px;
    color: var(--muted);
    background: var(--surface);
  }

  .expressive-code {
    margin: 1.35rem 0;
  }

  .expressive-code .frame {
    overflow: hidden;
  }

  .expressive-code .header::before {
    content: "";
    display: inline-block;
    width: 42px;
    height: 12px;
    margin-left: 12px;
    background:
      radial-gradient(circle at 6px 6px, #ff6b6b 0 5px, transparent 5.5px),
      radial-gradient(circle at 21px 6px, #ffd166 0 5px, transparent 5.5px),
      radial-gradient(circle at 36px 6px, #63d471 0 5px, transparent 5.5px);
  }

  .callout {
    margin: 1.25rem 0;
    padding: 15px 16px;
    border: 1px solid var(--line);
    border-left: 4px solid var(--accent);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.66);
  }

  .callout-title {
    margin: 0 0 6px;
    color: var(--text);
    font-weight: 820;
  }

  .callout-body > :first-child {
    margin-top: 0;
  }

  .callout-body > :last-child {
    margin-bottom: 0;
  }

  .callout-info { border-left-color: var(--blue); }
  .callout-note { border-left-color: var(--accent); }
  .callout-tip,
  .callout-success { border-left-color: var(--green); }
  .callout-warning { border-left-color: var(--amber); }
  .callout-danger { border-left-color: var(--rose); }

  .content-details {
    margin: 1.25rem 0;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.68);
    overflow: hidden;
    transition: border-color 180ms ease, box-shadow 180ms ease;
  }

  .content-details[open] {
    border-color: rgba(79, 159, 139, 0.28);
    box-shadow: 0 14px 34px rgba(79, 103, 96, 0.1);
  }

  .content-details summary {
    position: relative;
    cursor: pointer;
    padding: 14px 44px 14px 16px;
    color: var(--text);
    font-weight: 780;
    list-style: none;
  }

  .content-details summary::-webkit-details-marker {
    display: none;
  }

  .content-details summary::after {
    content: "+";
    position: absolute;
    right: 16px;
    top: 50%;
    width: 24px;
    height: 24px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent-strong);
    transform: translateY(-50%);
  }

  .content-details[open] summary::after {
    content: "-";
  }

  .content-details > div,
  .content-details > :not(summary) {
    padding: 0 16px 16px;
  }

  .spoiler-text {
    border-radius: 8px;
    padding: 0 4px;
    filter: blur(5px);
    background: rgba(217, 137, 165, 0.18);
    cursor: pointer;
    transition: filter 160ms ease, background 160ms ease;
  }

  .spoiler-text:hover,
  .spoiler-text:focus,
  .spoiler-text.is-revealed {
    filter: blur(0);
    background: rgba(217, 137, 165, 0.1);
  }

  .content-columns,
  .mdx-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(240px, 100%), 1fr));
    gap: 14px;
    margin: 1.25rem 0;
  }

  .content-columns > div,
  .mdx-card-grid > *,
  .content-timeline,
  .content-gallery,
  .mdx-figure,
  .image-compare {
    border: 1px solid var(--line);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.68);
    padding: 14px;
  }

  .link-card {
    display: block;
    border-radius: 18px;
    color: var(--text);
    text-decoration: none;
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .link-card:hover {
    transform: translateY(-2px);
    border-color: rgba(79, 159, 139, 0.28);
  }

  .link-card span {
    color: var(--accent-strong);
    font-size: 0.76rem;
    font-weight: 820;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .link-card strong {
    display: block;
