---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const renderedNotes = await Promise.all(
  notes.map(async (note) => {
    const { Content } = await render(note);
    return { note, Content };
  }),
);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
  }).format(date);
---

<BaseLayout title="说说" description="Alpha Blog 的短记录。">
  <section class="section-heading">
    <div>
      <p class="page-kicker">Notes</p>
      <h1 class="page-title">说说</h1>
    </div>
  </section>

  <section class="notes-grid" aria-label="说说列表">
    {renderedNotes.map(({ note, Content }) => (
      <article class="note-card">
        <p class="post-meta">
          <time datetime={note.data.date.toISOString()}>{formatDate(note.data.date)}</time>
          <span>{note.data.mood}</span>
        </p>
        <h2>{note.data.title}</h2>
        <Content />
        {note.data.tags.length > 0 ? (
          <ul class="tag-list">
            {note.data.tags.map((tag) => <li><a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a></li>)}
          </ul>
        ) : null}
      </article>
    ))}
  </section>
</BaseLayout>
