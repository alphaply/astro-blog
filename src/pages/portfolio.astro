---
import BaseLayout from '../layouts/BaseLayout.astro';

const works = [
  {
    title: 'Alpha Blog',
    status: 'Active',
    description: '基于 Astro、MDX 和 Vercel 的静态博客，用代码管理内容，保留搜索、评论、归档和作品展示。',
    href: '/',
  },
  {
    title: '内容系统迁移',
    status: 'Planning',
    description: '把旧博客内容整理成分类、标签、归档和可复用 MDX 组件。',
    href: '/archives/',
  },
  {
    title: 'MDX 组件库',
    status: 'Building',
    description: '沉淀公式、代码、图库、时间线、链接卡片和提示块等常用写作组件。',
    href: '/blog/welcome/',
  },
];
---

<BaseLayout title="作品" description="Alpha Blog 的项目和实验记录。">
  <section class="section-heading">
    <div>
      <p class="page-kicker">Portfolio</p>
      <h1 class="page-title">作品</h1>
    </div>
  </section>

  <section class="portfolio-grid" aria-label="作品列表">
    {works.map((work) => (
      <article class="portfolio-card">
        <p class="page-kicker">{work.status}</p>
        <h2><a href={work.href}>{work.title}</a></h2>
        <p>{work.description}</p>
      </article>
    ))}
  </section>
</BaseLayout>
