---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const groups = new Map<number, typeof posts>();
for (const post of posts) {
  const year = post.data.date.getFullYear();
  groups.set(year, [...(groups.get(year) ?? []), post]);
}

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('zh-CN', {
    month: '2-digit',
    day: '2-digit',
  }).format(date);
---

<BaseLayout title="归档" description="按时间浏览 Alpha Blog 的文章。">
  <section class="section-heading">
    <div>
      <p class="page-kicker">Archives</p>
      <h1 class="page-title">归档</h1>
    </div>
    <p>{posts.length} 篇文章</p>
  </section>

  {[...groups.entries()].map(([year, yearPosts]) => (
    <section class="archive-year">
      <h2>{year}</h2>
      <ul class="archive-list">
        {yearPosts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`}>
              <time>{formatDate(post.data.date)}</time>
              <span>{post.data.title}</span>
              <small>{post.data.category}</small>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>
