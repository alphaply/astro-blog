---
interface Props {
  href: string;
  title: string;
  description?: string;
  label?: string;
}

const { href, title, description = '', label = 'Link' } = Astro.props;
---

<a class="link-card" href={href}>
  <span>{label}</span>
  <strong>{title}</strong>
  {description ? <p>{description}</p> : null}
</a>
